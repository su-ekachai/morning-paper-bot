# LLM provider: "anthropic" (default) or "openai" (any OpenAI-compatible API)
LLM_PROVIDER=anthropic

# Model. Anthropic path defaults to claude-opus-4-8 if unset. Required on openai path.
#LLM_MODEL=claude-opus-4-8

# Anthropic path
ANTHROPIC_API_KEY=sk-xxx-...

# OpenAI-compatible path (OpenAI / OpenRouter / Ollama)
#OPENAI_BASE_URL=https://api.openai.com/v1
#OPENAI_API_KEY=sk-...

# Delivery — each channel is enabled when its vars are set
#DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
#TELEGRAM_BOT_TOKEN=123456:ABC-...
#TELEGRAM_CHAT_ID=123456789
